{
  "compilerOptions": {
    "target": "ES2022",
    "rootDir": "./src",
    "module": "es2022",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "src/test"]
}
