{
  "name": "@alvarovfon/opencode-agent-monitor",
  "version": "0.1.1",
  "description": "OpenCode plugin for tracing LLM calls, agent delegations, tool calls and session events to JSONL files",
  "type": "commonjs",
  "main": "src/agent-monitor.ts",
  "exports": {
    ".": "./src/agent-monitor.ts"
  },
  "scripts": {
