{
  "name": "@alvarovfon/opencode-agent-monitor",
  "version": "1.0.1",
  "description": "OpenCode plugin for tracing LLM calls, agent delegations, tool calls and session events to JSONL files",
  "type": "commonjs",
  "main": "dist/agent-monitor.js",
  "types": "dist/agent-monitor.d.ts",
  "exports": {
    ".": {
      "types": "./dist/agent-monitor.d.ts",
      "import": "./dist/agent-monitor.js",
      "require": "./dist/agent-monitor.js",
      "default": "./dist/agent-monitor.js"
    },
    "./tui": {
      "types": "./dist/tui-detect.d.ts",
      "import": "./dist/tui-detect.js",
      "require": "./dist/tui-detect.js",
      "default": "./dist/tui-detect.js"
    },
    "./tui/real": {
      "types": "./dist/agent-monitor-tui.d.ts",
      "import": "./dist/agent-monitor-tui.js",
      "require": "./dist/agent-monitor-tui.js",
      "default": "./dist/agent-monitor-tui.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "node --import tsx --experimental-test-module-mocks --test 'src/test/**/*.test.ts'",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "metrics": "tsx scripts/metrics.mts",
    "prepare": "husky",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build && pnpm run lint && pnpm run format:check && pnpm test"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.50",
    "@opencode-ai/sdk": "^1.x",
    "solid-js": "^1.9.0"
  },
  "peerDependencies": {
    "@opentui/core": "^0.3.4",
    "@opentui/keymap": "^0.3.4",
    "@opentui/solid": "^0.3.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "esbuild-plugin-solid": "^0.6.0",
    "husky": "^9",
    "js-yaml": "^4.2.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsup": "^8.5.0",
    "tsx": "^4",
    "typescript": "~5.8.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "package.json",
    "tsconfig.json",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "license": "MIT",
  "author": "Alvaro Villamarin <alvaro.vfon@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlvaroVFon/opencode-agent-monitor.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tracing",
    "telemetry"
  ]
}
