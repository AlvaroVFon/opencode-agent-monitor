{
  "name": "@alvarovfon/opencode-agent-monitor",
  "version": "1.0.0",
  "description": "OpenCode plugin for tracing LLM calls, agent delegations, tool calls and session events to JSONL files",
  "type": "commonjs",
  "main": "src/server/agent-monitor.ts",
  "exports": {
    ".": "./src/server/agent-monitor.ts",
    "./tui": {
      "import": "./src/tui/tui-detect.ts",
      "types": "./src/tui/tui-detect.ts"
    },
    "./tui/real": {
      "import": "./src/tui/agent-monitor-tui.tsx",
      "types": "./src/tui/agent-monitor-tui.tsx"
    }
  },
  "scripts": {
    "test": "node --import tsx --experimental-test-module-mocks --test 'src/test/**/*.test.ts'",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "metrics": "tsx scripts/metrics.mts",
    "prepare": "husky",
    "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm test"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.50",
    "@opencode-ai/sdk": "^1.x",
    "solid-js": "^1.9.0"
  },
  "peerDependencies": {
    "@opentui/core": "^0.3.4",
    "@opentui/keymap": "^0.3.4",
    "@opentui/solid": "^0.3.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "husky": "^9",
    "js-yaml": "^4.2.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "src/",
    "tui.json",
    "package.json",
    "tsconfig.json",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "license": "MIT",
  "author": "Alvaro Villamarin <alvaro.vfon@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlvaroVFon/opencode-agent-monitor.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tracing",
    "telemetry"
  ]
}
